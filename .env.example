# Copy to .env and fill in. Every var below is read by src/config.py.

# --- Required: startup fails loudly if any of these are missing ---

# OpenAI API key used for all agent reasoning.
OPENAI_API_KEY=sk-...

# Redis connection URL. Backs LangGraph checkpoints and run-state caching.
# docker-compose provides this as redis://redis:6379/0
REDIS_URL=redis://localhost:6379/0

# SQLite file holding run history / the audit log of state transitions.
DB_PATH=./data/runs.db

# --- Optional: sensible defaults in src/config.py ---

# Root directory for per-run artifacts (plots, .pptx, .pkl).
RUNS_DIR=./runs

# Model used for planning and narrative work.
REASONING_MODEL=gpt-4o

# Cheaper model used for mechanical sub-tasks.
CHEAP_MODEL=gpt-4o-mini

# Hard cap on total LLM spend per run, in USD. The run ends when it is hit.
MAX_RUN_COST_USD=2.0

# Wall-clock timeout, in seconds, for a single sandboxed code execution.
SANDBOX_TIMEOUT_S=120

# Address-space cap, in MB, for a single sandboxed code execution.
SANDBOX_MEMORY_MB=2048

# Runs with confidence below this threshold escalate to a human.
CONFIDENCE_THRESHOLD=0.6

# --- Dashboard only ---

# Base URL the Streamlit dashboard uses to reach the API.
# docker-compose provides this as http://api:8000
API_BASE_URL=http://localhost:8000
