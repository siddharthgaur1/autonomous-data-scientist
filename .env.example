# Copy to .env and fill in. Every var below is read by src/config.py.

# --- Required: startup fails loudly if this is missing ---

# LLM API key used for all agent reasoning.
#  - Paid: an OpenAI key (sk-...), leave OPENAI_BASE_URL empty.
#  - FREE: a Groq key (gsk_...) from https://console.groq.com/keys, and set
#    OPENAI_BASE_URL + REASONING_MODEL below. Groq is OpenAI-compatible, so the
#    entire agent graph runs on its free tier with no code change.
OPENAI_API_KEY=sk-...

# --- Optional: sensible defaults in src/config.py ---

# OpenAI-compatible base URL. Empty = OpenAI. Point it at a free provider to run
# without paid usage. Examples:
#   Groq:       https://api.groq.com/openai/v1   (then REASONING_MODEL=llama-3.3-70b-versatile)
#   OpenRouter: https://openrouter.ai/api/v1
#   Ollama:     http://localhost:11434/v1        (fully offline, no key needed)
OPENAI_BASE_URL=

# Redis connection URL. Backs LangGraph checkpoints and run-state caching.
# OPTIONAL — if Redis is unreachable the run degrades to in-memory and still
# reaches an answer. docker-compose provides this as redis://redis:6379/0
REDIS_URL=redis://localhost:6379/0

# SQLite file holding run history / the audit log of state transitions.
DB_PATH=./data/runs.db

# Root directory for per-run artifacts (plots, .pptx, .pkl).
RUNS_DIR=./runs

# Model used for planning and narrative work.
REASONING_MODEL=gpt-4o

# Cheaper model used for mechanical sub-tasks.
CHEAP_MODEL=gpt-4o-mini

# Hard cap on total LLM spend per run, in USD. The run ends when it is hit.
MAX_RUN_COST_USD=2.0

# Wall-clock timeout, in seconds, for a single sandboxed code execution.
SANDBOX_TIMEOUT_S=120

# Address-space cap, in MB, for a single sandboxed code execution.
SANDBOX_MEMORY_MB=2048

# Runs with confidence below this threshold escalate to a human.
CONFIDENCE_THRESHOLD=0.6

# --- Dashboard only ---

# Base URL the Streamlit dashboard uses to reach the API.
# docker-compose provides this as http://api:8000
API_BASE_URL=http://localhost:8000
